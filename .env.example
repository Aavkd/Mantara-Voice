# Mantara Voice Inbox — variables d'environnement du backend (machine Mantara).
# Copiez ce fichier en `.env.local` et remplissez les valeurs. NE JAMAIS commiter `.env.local`.
# Reference : SPEC_DESIGN.md section 9.4.

# --- Base de donnees (Postgres local) ---
DATABASE_URL=postgres://user:pass@localhost:5432/mantara_voice_inbox

# --- Auth.js (NextAuth) ---
AUTH_SECRET=                                  # secret de signature des sessions (openssl rand -base64 32)
AUTH_URL=https://api.mantara-voice.fr         # URL publique du backend (tunnel Cloudflare)
COOKIE_DOMAIN=.mantara-voice.fr               # cookie de session partage entre sous-domaines
CORS_ALLOWED_ORIGIN=https://app.mantara-voice.fr

# --- IA ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001     # modele LLM, changeable sans toucher au code
AI_ANALYSIS_PROVIDER=                          # optionnel: anthropic|mock ; vide = anthropic si cle presente, sinon mock
WHISPER_MODEL=medium                          # taille du modele Whisper local (tiny|base|small|medium|large)
WHISPER_BACKEND=                              # optionnel: faster-whisper|openai-whisper|whisper-cpp ; vide = auto
WHISPER_EXECUTABLE=                           # optionnel: chemin vers whisper, whisper-cli, etc.
WHISPER_PYTHON_EXECUTABLE=                    # optionnel: chemin vers python pour faster-whisper
WHISPER_CPP_MODEL_PATH=                       # requis si WHISPER_BACKEND=whisper-cpp
WHISPER_LANGUAGE=fr
WHISPER_TIMEOUT_MS=600000

# --- Email transactionnel ---
RESEND_API_KEY=

# --- Frontend (Vercel) : a definir cote Vercel, pas ici ---
# NEXT_PUBLIC_API_BASE_URL=https://api.mantara-voice.fr
